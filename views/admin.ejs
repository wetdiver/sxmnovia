<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background: #0a0a0a; }
        .admin-container { padding: 1rem; }
        .member-card { background: #1a1a1a; border-radius: 16px; padding: 1rem; margin-bottom: 1rem; }
        .member-card img { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; }
        .form-dark { background: #1a1a1a; padding: 1.5rem; border-radius: 16px; margin-bottom: 2rem; }
    </style>
</head>
<body>
<div class="container admin-container">
    <h1>Admin Panel</h1>
    
    <ul class="nav nav-tabs" id="myTab">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#members">Members</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#properties">Properties</button></li>
    </ul>
    
    <div class="tab-content mt-4">
        <!-- Members Tab -->
        <div class="tab-pane active" id="members">
            <div class="form-dark">
                <h3>Add Member</h3>
                <form method="post" action="/admin/members" enctype="multipart/form-data">
                    <input type="text" name="name" class="form-control mb-2" placeholder="Name" required>
                    <textarea name="bio" class="form-control mb-2" rows="3" placeholder="Bio"></textarea>
                    <input type="file" name="image" class="form-control mb-2" accept="image/*">
                    <button type="submit" class="btn btn-primary">Add Member</button>
                </form>
            </div>
            
            <h3>Existing Members</h3>
            <% members.forEach(m => { %>
            <div class="member-card d-flex align-items-start gap-3">
                <img src="<%= m.image || '/uploads/default-avatar.png' %>">
                <div class="flex-grow-1">
                    <h4><%= m.name %></h4>
                    <p><%= m.bio || '' %></p>
                    <div class="mt-2">
                        <button class="btn btn-sm btn-primary" onclick="editMember(<%= m.id %>, '<%= m.name.replace(/'/g, "\\'") %>', '<%= m.bio ? m.bio.replace(/'/g, "\\'") : '' %>')">Edit</button>
                        <a href="/admin/members/<%= m.id %>/delete" class="btn btn-sm btn-danger" onclick="return confirm('Delete this member?')">Delete</a>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
        
        <!-- Properties Tab -->
        <div class="tab-pane" id="properties">
            <div class="form-dark">
                <h3>Add Property</h3>
                <form method="post" action="/admin/properties">
                    <input type="text" name="title" class="form-control mb-2" placeholder="Title" required>
                    <input type="text" name="video" class="form-control mb-2" placeholder="Video URL">
                    <button type="submit" class="btn btn-primary">Add Property</button>
                </form>
            </div>
            <ul class="list-group">
                <% properties.forEach(p => { %>
                <li class="list-group-item bg-dark text-white d-flex justify-content-between">
                    <%= p.title %> - <a href="<%= p.video %>" target="_blank">video</a>
                    <a href="/admin/properties/<%= p.id %>/delete" class="btn btn-sm btn-danger" onclick="return confirm('Delete?')">Delete</a>
                </li>
                <% }); %>
            </ul>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header">
                <h5 class="modal-title">Edit Member</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" enctype="multipart/form-data" id="editForm">
                <div class="modal-body">
                    <input type="text" name="name" id="editName" class="form-control mb-2" required>
                    <textarea name="bio" id="editBio" class="form-control mb-2" rows="3"></textarea>
                    <input type="file" name="image" class="form-control mb-2" accept="image/*">
                    <small class="text-muted">Leave empty to keep current image</small>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function editMember(id, name, bio) {
        document.getElementById('editForm').action = '/admin/members/' + id;
        document.getElementById('editName').value = name;
        document.getElementById('editBio').value = bio;
        new bootstrap.Modal(document.getElementById('editModal')).show();
    }
</script>
</body>
</html>