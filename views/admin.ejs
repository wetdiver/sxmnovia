<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">
    <h1>Admin Panel</h1>
    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#members">Members</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#properties">Properties</button></li>
    </ul>
    <div class="tab-content mt-3">
        <div class="tab-pane active" id="members">
            <form method="post" action="/admin/members" enctype="multipart/form-data" class="mb-4">
                <input type="text" name="name" placeholder="Name" required>
                <textarea name="bio" placeholder="Bio"></textarea>
                <input type="file" name="image" accept="image/*">
                <button type="submit">Add Member</button>
            </form>
            <table class="table">
                <% members.forEach(m => { %>
                <tr>
                    <td><img src="<%= m.image %>" width="50"></td>
                    <td><%= m.name %></td>
                    <td><%= m.bio %></td>
                    <td>
                        <form method="post" action="/admin/members/<%= m.id %>" enctype="multipart/form-data" style="display:inline-block">
                            <input type="text" name="name" value="<%= m.name %>">
                            <textarea name="bio"><%= m.bio %></textarea>
                            <input type="file" name="image">
                            <button type="submit">Edit</button>
                        </form>
                        <a href="/admin/members/<%= m.id %>/delete" class="btn btn-danger">Delete</a>
                    </td>
                </tr>
                <% }); %>
            </table>
        </div>
        <div class="tab-pane" id="properties">
            <form method="post" action="/admin/properties">
                <input type="text" name="title" placeholder="Title">
                <input type="text" name="video" placeholder="Video URL">
                <button type="submit">Add Property</button>
            </form>
            <ul>
                <% properties.forEach(p => { %>
                <li><%= p.title %> - <a href="<%= p.video %>">video</a> <a href="/admin/properties/<%= p.id %>/delete">delete</a></li>
                <% }); %>
            </ul>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>